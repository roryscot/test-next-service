version: "3.8"

services:
  nextjs:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: interview_strella_api
    environment:
      - NODE_ENV=development
      - LIVEKIT_URL=wss://localhost:7880
      - LIVEKIT_API_KEY=devkey
      - LIVEKIT_API_SECRET=secret
      - OPENAI_API_KEY=${OPENAI_API_KEY:-sk-your-openai-api-key-here}
    ports:
      - "3000:3000"
    volumes:
      - .:/app
      - /app/node_modules
      - /app/.next
    command: >
      sh -c "
        echo '🚀 Starting Next.js...' &&
        npm run dev
      "
    networks:
      - strella_network
    restart: unless-stopped

volumes:
  redis_data:

networks:
  strella_network:
    driver: bridge
