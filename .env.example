# Environment Variables for Complete Interview System

NODE_ENV=development

# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# LiveKit Configuration
# Get these from https://cloud.livekit.io/ or your self-hosted LiveKit instance
LIVEKIT_URL="wss://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="secret"

# OpenAI Configuration (for AI agent)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview-2024-12-17"
OPENAI_VOICE=alloy
OPENAI_TEMPERATURE=0.7

MAX_SESSION_SECONDS=300


# Server Configuration (optional)
SERVER_ORIGIN="http://localhost:3000"

# Logging Configuration (optional)
LOG_LEVEL="info"

# Rate Limiting (optional - for production)
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."